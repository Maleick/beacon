{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["verdict", "summary"],
  "properties": {
    "verdict": { "enum": ["PASS", "FAIL"] },
    "summary": { "type": "string" },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "met"],
        "properties": {
          "text": { "type": "string" },
          "met": { "type": "boolean" },
          "evidence": { "type": "string" }
        }
      }
    },
    "risks": { "type": "array", "items": { "type": "string" } }
  }
}
