{
  "name": "beacon",
  "description": "Autonomous multi-agent orchestration for Claude Code. Routes GitHub issues to AI agents, verifies results, and merges PRs.",
  "author": {
    "name": "Maleick",
    "url": "https://github.com/Maleick"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/beacon-activate.sh",
            "timeout": 15,
            "statusMessage": "Initializing Beacon..."
          }
        ]
      }
    ]
  }
}
